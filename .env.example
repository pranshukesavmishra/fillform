# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development                  # development | staging | production
APP_NAME=FillFormAI
APP_VERSION=1.0.0
DEBUG=true

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-64-char-random-hex-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30
ENCRYPTION_KEY=change-me-to-32-char-fernet-key

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fillformai
POSTGRES_USER=fillform
POSTGRES_PASSWORD=supersecretpassword
DATABASE_URL=postgresql+asyncpg://fillform:supersecretpassword@postgres:5432/fillformai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2

# ── MongoDB (Document store) ──────────────────────────────────────────────────
MONGO_URL=mongodb://mongo:27017
MONGO_DB=fillformai_docs

# ── AWS S3 (Document Storage) ─────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1
S3_BUCKET=fillformai-documents
S3_ENDPOINT_URL=                     # Leave blank for real AWS; set for MinIO

# ── AI / LLM ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=text-embedding-3-small
PINECONE_API_KEY=
PINECONE_INDEX=fillformai-opportunities

# ── Communication ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
WHATSAPP_BUSINESS_TOKEN=...
WHATSAPP_PHONE_NUMBER_ID=...
SENDGRID_API_KEY=SG...
FROM_EMAIL=noreply@fillformai.in

# ── Payments ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...

# ── Aadhaar / DigiLocker ──────────────────────────────────────────────────────
DIGILOCKER_CLIENT_ID=...
DIGILOCKER_CLIENT_SECRET=...
DIGILOCKER_REDIRECT_URI=https://app.fillformai.in/auth/digilocker/callback

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_AI_FORM_FILL=true
ENABLE_CAREER_TWIN=true
ENABLE_AGENT_MARKETPLACE=true
ENABLE_WHATSAPP_NOTIFICATIONS=false  # Enable after WhatsApp API approval

# ── Service URLs (internal) ───────────────────────────────────────────────────
AUTH_SERVICE_URL=http://auth-service:8001
PROFILE_SERVICE_URL=http://profile-service:8002
OPPORTUNITY_SERVICE_URL=http://opportunity-service:8003
APPLICATION_SERVICE_URL=http://application-service:8004
DOCUMENT_SERVICE_URL=http://document-service:8005
AGENT_SERVICE_URL=http://agent-service:8006
NOTIFICATION_SERVICE_URL=http://notification-service:8007
AI_SERVICE_URL=http://ai-service:8008
PAYMENT_SERVICE_URL=http://payment-service:8009

# ── API Gateway ───────────────────────────────────────────────────────────────
API_GATEWAY_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,https://fillformai.in,https://app.fillformai.in

# ── Kafka (Event Streaming) ───────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=fillformai-consumers
